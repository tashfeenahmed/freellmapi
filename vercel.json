{
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "client/dist",
  "functions": {
    "api/index.js": {
      "includeFiles": "server/dist/**,client/dist/**",
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index"
    },
    {
      "source": "/v1/:path*",
      "destination": "/api/index"
    },
    {
      "source": "/:path*",
      "destination": "/api/index"
    }
  ]
}
