# FreeLLMAPI Orchestrator Configuration
# Copy to .env in skill directory and fill in values

# FreeLLMAPI base URL (change if running on different host/port)
FREELLAPI_BASE=http://localhost:3001/v1

# Unified API key from FreeLLMAPI dashboard (Keys page)
# Get this from http://localhost:3001/keys
FREELLAPI_KEY=freellmapi-your-unified-key-here

# Optional: Dashboard auth token for /api/fallback/routing access
# Get via FreeLLMAPI login flow or API
# FREELLAPI_DASH_TOKEN=your-dashboard-session-token

# Default system prompt injected at proxy level (optional)
# DEFAULT_SYSTEM_PROMPT=You are a concise, helpful assistant. Never use markdown unless asked.

# Request timeout in seconds
DEFAULT_TIMEOUT=120
