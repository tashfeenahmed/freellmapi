# Native deploy — copy to deploy/.env
#
# Runtime: llmapi.service + llm-nginx.service share llm.nalits.slice
# (MemoryMax=400M, MemorySwapMax=0). npm build and certbot are outside that cap.

# Public hostname (DNS + TLS + nginx server_name)
DOMAIN=llm.nalits.com

# Let's Encrypt registration (used by start-stack when issuing certs)
SSL_EMAIL=you@example.com

# 64 hex chars:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-char-hex-key-here

PORT=3001
HOST=127.0.0.1
NODE_ENV=production
NODE_OPTIONS=--max-old-space-size=256
RESPONSE_CACHE=false
FREEAPI_BLOCK_PRIVATE_PROVIDER_URLS=true
